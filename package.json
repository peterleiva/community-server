{
  "name": "community-server",
  "description": "Forum application api with GraphQL server",
  "version": "0.3.0-canary.2",
  "author": "Peter Leiva <pleiva@id.uff.br>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "prestart": "npm run build && chmod 600 ./dist/index.bundle.js",
    "start": "dist/index.bundle.js",
    "build": "webpack --env mode=production",
    "dev": "concurrently \"npm:watch:*\"",
    "watch:webpack": "webpack --watch --env mode=development",
    "watch:nodemon": "nodemon dist/index.bundle.js",
    "format": "prettier --write .",
    "test": "jest",
    "open:coverage-report": "open coverage/index.html"
  },
  "dependencies": {
    "apollo-server-express": "^2.17.0",
    "casual": "^1.6.2",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^8.2.0",
    "express": "~4.16.1",
    "faker": "^5.1.0",
    "graphql-scalars": "^1.2.7",
    "lodash": "^4.17.20",
    "loglevel": "^1.7.1",
    "mongoose": "^5.11.16",
    "mongoose-autopopulate": "^0.12.2",
    "morgan": "~1.9.1",
    "rosie": "^2.0.1"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^1.2.3",
    "@tsconfig/node14": "^1.0.0",
    "@types/cookie-parser": "^1.4.2",
    "@types/cors": "^2.8.7",
    "@types/debug": "^4.1.5",
    "@types/express": "^4.17.8",
    "@types/faker": "^5.1.0",
    "@types/jest": "^26.0.13",
    "@types/lodash": "^4.14.161",
    "@types/mongoose-autopopulate": "^0.10.1",
    "@types/morgan": "^1.9.1",
    "@types/node": "^14.14.31",
    "@types/rosie": "0.0.38",
    "@typescript-eslint/eslint-plugin": "^4.1.1",
    "@typescript-eslint/parser": "^4.1.1",
    "concurrently": "^6.0.0",
    "eslint": "^7.9.0",
    "eslint-config-prettier": "^6.11.0",
    "fork-ts-checker-notifier-webpack-plugin": "^3.0.0",
    "fork-ts-checker-webpack-plugin": "^6.1.0",
    "jest": "^26.4.2",
    "jest-extended": "^0.11.5",
    "nodemon": "^2.0.7",
    "open": "^7.4.2",
    "prettier": "2.1.1",
    "ts-jest": "^26.5.1",
    "ts-loader": "^8.0.17",
    "tsconfig-paths-webpack-plugin": "^3.3.0",
    "typescript": "^4.0.2",
    "webpack": "^5.24.2",
    "webpack-cli": "^4.5.0",
    "webpack-dev-server": "^3.11.2",
    "webpack-merge": "^5.7.3",
    "webpack-node-externals": "^2.5.2"
  }
