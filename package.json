{
  "name": "community",
  "description": "Forum application server",
  "version": "0.1.0",
  "author": "Peter Leiva <pleiva@id.uff.br>",
  "license": "MIT",
  "private": false,
  "bin": "dist/main.js",
  "engines": {
    "node": ">=12.18.3"
  },
  "scripts": {
    "start": "npm run build && dist/main.js",
    "start:live": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "npm run lint && npm run cp-statics && tsc --build && chmod u+x dist/main.js",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "lint:fix": "npm run lint --fix",
    "cp-statics": "./copy-files.js",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "test": "jest"
  },
  "dependencies": {
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^8.2.0",
    "express": "~4.16.1",
    "mongoose": "^5.10.5",
    "morgan": "~1.9.1"
  },
  "devDependencies": {
    "@tsconfig/node12": "^1.0.7",
    "@tsconfig/recommended": "^1.0.1",
    "@types/cookie-parser": "^1.4.2",
    "@types/cors": "^2.8.7",
    "@types/debug": "^4.1.5",
    "@types/express": "^4.17.8",
    "@types/jest": "^26.0.13",
    "@types/mongoose": "^5.7.36",
    "@types/morgan": "^1.9.1",
    "@typescript-eslint/eslint-plugin": "^4.1.1",
    "@typescript-eslint/parser": "^4.1.1",
    "eslint": "^7.9.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-tsdoc": "^0.2.7",
    "jest": "^26.4.2",
    "prettier": "2.1.1",
    "shelljs": "^0.8.4",
    "ts-jest": "^26.3.0",
    "ts-node-dev": "^1.0.0-pre.62",
    "typescript": "^4.0.2"
  }
}
