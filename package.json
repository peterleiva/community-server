  "private": false,
  "bin": "dist/main.js",
  "engines": {
    "node": ">=12.18.3"
  },
  "scripts": {
    "start": "npm run build && dist/main.js",
    "dev": "ts-node-dev --project tsconfig.build.json  --respawn --transpile-only src/main.ts",
    "build": "npm run lint && tsc -b && chmod 500 dist/main.js",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "format": "prettier --write .",
    "test": "jest"
  },
  "dependencies": {
    "@types/mongoose-autopopulate": "^0.10.1",
    "apollo-server-express": "^2.17.0",
    "casual": "^1.6.2",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "faker": "^5.1.0",
    "graphql-scalars": "^1.2.7",
    "lodash": "^4.17.20",
    "mongoose": "^5.10.5",
    "mongoose-autopopulate": "^0.12.2",
    "morgan": "~1.9.1",
    "rosie": "^2.0.1"
  },
  "devDependencies": {
    "@tsconfig/node14": "^1.0.0",
    "@tsconfig/recommended": "^1.0.1",
    "@types/cookie-parser": "^1.4.2",
    "@types/cors": "^2.8.7",
    "@types/debug": "^4.1.5",
    "@types/express": "^4.17.8",
    "@types/faker": "^5.1.0",
    "@types/jest": "^26.0.13",
    "@types/lodash": "^4.14.161",
    "@types/mongoose": "^5.7.36",
    "@types/morgan": "^1.9.1",
    "@types/rosie": "0.0.38",
    "@typescript-eslint/eslint-plugin": "^4.1.1",
    "@typescript-eslint/parser": "^4.1.1",
    "dotenv": "^8.2.0",
    "eslint": "^7.9.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-tsdoc": "^0.2.7",
    "jest": "^26.4.2",
    "jest-extended": "^0.11.5",
    "loglevel": "^1.7.0",
    "prettier": "2.1.1",
    "shelljs": "^0.8.4",
    "ts-jest": "^26.5.1",
    "ts-node-dev": "^1.0.0-pre.62",
    "typescript": "^4.0.2"
  }
