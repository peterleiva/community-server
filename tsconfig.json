{
  "extends": "@tsconfig/node12/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noImplicitAny": true,
    "resolveJsonModule": true,

    "baseUrl": "./src",
    "paths": {
      "@config/*": ["./config/*"],
      "@lib/*": ["./lib/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
