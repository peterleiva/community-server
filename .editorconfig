# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true

# Matches multiple files with brace expansion notation
# Set default charset
[*.{js,ts}]
charset = utf-8
indent_size = 2

# Indentation override for all TS under lib directory
[src/**/*.ts]
indent_style = tab
trim_trailing_whitespace = true

# Matches the exact  either .travis.yml or jest.config.js and config .json
[{.travis.yml, jest.config.js, *.json}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
